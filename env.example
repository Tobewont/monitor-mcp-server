# ============================================================================
# 查询地址（必填）— 指向 Prometheus / Thanos Query / Mimir Gateway / VM vmselect
# ============================================================================
PROMETHEUS_URL=http://your-prometheus-server:9090

# ============================================================================
# 后端类型（可选，默认 prometheus）
# 可选值：prometheus / thanos / mimir / victoriametrics
# 仅影响 API 路径前缀：
#   - prometheus / thanos / victoriametrics → /api/v1
#   - mimir → /prometheus/api/v1（且强烈建议配 ORG_ID）
# ============================================================================
# BACKEND_TYPE=prometheus

# 告警/规则查询地址（可选，多数情况下不需要配置）
#   Prometheus 原生 / Thanos Query / Mimir (via Gateway)：查询入口本身即包含
#     /api/v1/alerts 和 /api/v1/rules，留空即可。
#   VictoriaMetrics：vmselect 不提供 alerts/rules，需要将 RULER_URL 指向 vmalert。
#   Thanos 场景：不要指向单个 Thanos Ruler 实例，那样只能看到该副本分片的告警；
#     正确做法是留空，让请求走 Thanos Query 聚合全量。
# RULER_URL=http://vmalert:8880

# ----------------------------------------------------------------------------
# 各后端推荐配置示例
# ----------------------------------------------------------------------------
# 【示例 1】Prometheus 原生
#   PROMETHEUS_URL=http://prometheus.monitoring:9090
#   BACKEND_TYPE=prometheus
#
# 【示例 2】Thanos Query（多副本 Ruler 聚合）
#   PROMETHEUS_URL=http://thanos-query.monitoring:9090
#   BACKEND_TYPE=thanos
#   # 不要设 RULER_URL，让 alerts/rules 走 Thanos Query 拿到聚合全量
#
# 【示例 3】Grafana Mimir（多租户）
#   PROMETHEUS_URL=http://mimir-gateway.monitoring
#   BACKEND_TYPE=mimir
#   ORG_ID=tenant-1
#   # 默认会自动加 /prometheus/api/v1 前缀
#
# 【示例 4】VictoriaMetrics + vmalert
#   PROMETHEUS_URL=http://vmselect.monitoring:8481
#   BACKEND_TYPE=victoriametrics
#   RULER_URL=http://vmalert.monitoring:8880

# 认证配置（按需选择以下认证方式之一）
# PROMETHEUS_USERNAME=your_username
# PROMETHEUS_PASSWORD=your_password
# PROMETHEUS_TOKEN=your_token

# 多租户 OrgID（Thanos / Mimir 等）
# ORG_ID=tenant-1

# MCP 服务器传输配置
# 可选值: stdio、sse、streamable-http，默认 stdio
# PROMETHEUS_MCP_SERVER_TRANSPORT=stdio
# 仅非 stdio 模式有效，默认 127.0.0.1
# PROMETHEUS_MCP_BIND_HOST=localhost
# 仅非 stdio 模式有效，默认 8000
# PROMETHEUS_MCP_BIND_PORT=8000

# 日志级别
# 可选值: DEBUG、INFO、WARNING、ERROR，默认 INFO
# LOG_LEVEL=INFO

# ============================================================================
# monitor-agent 配置管理（可选，默认关闭）
# ============================================================================
# 开启后会注册 monitor_agent_* MCP 工具，用于管理 S3 兼容对象存储中的
# monitor-agent YAML 采集配置，并可调用 monitor-agent /reload 重载配置。
# MONITOR_AGENT_CONFIG_ENABLED=false

# S3 兼容对象存储配置（开启后必填）
# MONITOR_AGENT_S3_ENDPOINT_URL=https://s3.example.com
# MONITOR_AGENT_S3_BUCKET=monitor-configs
# MONITOR_AGENT_S3_ACCESS_KEY_ID=your_access_key
# MONITOR_AGENT_S3_SECRET_ACCESS_KEY=your_secret_key
# MONITOR_AGENT_S3_REGION=us-east-1
# MONITOR_AGENT_S3_ADDRESSING_STYLE=path

# 配置文件与备份目录
# MONITOR_AGENT_CONFIG_PREFIX=monitor-agent/configs
# MONITOR_AGENT_BACKUP_PREFIX=monitor-agent/backups
# MONITOR_AGENT_CONFIG_EXTENSION=.yaml

# 通过机器 IP 查询资产编号。模板中的 {ip} 会被替换为用户传入的 IP；
# PromQL 自身的大括号无需转义。
# MONITOR_AGENT_ASSET_QUERY_TEMPLATE=up{instance=~"{ip}(:.*)?"}
# MONITOR_AGENT_ASSET_ID_LABELS=asset_id,asset_no,host_id,hostname

# monitor-agent reload 接口
# MONITOR_AGENT_RELOAD_URL_TEMPLATE=http://{ip}:12345/reload
# MONITOR_AGENT_RELOAD_TIMEOUT=10
